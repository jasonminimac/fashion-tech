# Database
DATABASE_URL=postgresql://developer:dev_password_123@localhost:5432/fashion_tech_dev

# S3 / MinIO (local dev)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin123
S3_ENDPOINT_URL=http://localhost:9000
S3_BUCKET=fashion-tech-storage

# JWT Secret (generate: openssl rand -hex 32)
JWT_SECRET_KEY=your_secret_key_here_generate_with_openssl_rand_-hex_32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# API
API_TITLE=Fashion Tech API
API_VERSION=0.1.0
ENVIRONMENT=development
DEBUG=True

# CORS
CORS_ORIGINS=["http://localhost:3000", "http://localhost:5173"]

# Logging
LOG_LEVEL=DEBUG
