# FashionTechScan Xcode Project Configuration
# This file defines the project structure for manual setup

PROJECT_NAME=FashionTechScan
BUNDLE_ID=com.fashiontech.scan
ORGANIZATION_ID=com.fashiontech
DEPLOYMENT_TARGET=14.5
SWIFT_VERSION=5.5

# Xcode Build Settings
IPHONEOS_DEPLOYMENT_TARGET = 14.5
TARGETED_DEVICE_FAMILY = 1  # iPhone only
SUPPORTS_MACCATALYST = NO

# Capabilities Required
CAPABILITIES = \
    ARKit \
    Camera \
    Motion

# Frameworks
FRAMEWORKS = \
    ARKit \
    RealityKit \
    Combine \
    SwiftUI \
    CoreMotion \
    CoreImage \
    Vision

# Dependencies (CocoaPods if needed)
# None for Week 1

# Source Files
SOURCES = \
    FashionTechScanApp.swift \
    ARCaptureView.swift \
    ARKitDepthCapture.swift \
    PointCloudWriter.swift

# Tests
TESTS = \
    ARKitDepthCaptureTests.swift \
    PointCloudWriterTests.swift

# Build Phases
COPY_BUNDLE_RESOURCES = \
    Assets.xcassets \
    how-to-scan.mp4

# Code Signing
CODE_SIGN_IDENTITY = iPhone Developer
PROVISIONING_PROFILE_SPECIFIER = iOS Team Provisioning Profile

# Compiler Flags
GCC_PREPROCESSOR_DEFINITIONS = \
    DEBUG=1 \
    DEVELOPER_BUILD=1

# Swift Compiler
SWIFT_OPTIMIZATION_LEVEL = -O  # Release: -Osize
